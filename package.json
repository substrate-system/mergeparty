{
  "name": "@substrate-system/mergeparty",
  "version": "0.0.2",
  "description": "Automerge + Partykit",
  "type": "module",
  "exports": {
    "./client": {
      "import": "./dist/client/partykit-websocket-adapter.js",
      "require": "./dist/client/partykit-websocket-adapter.cjs"
    },
    "./server": {
      "import": "./dist/server/index.js",
      "require": "./dist/server/index.cjs"
    },
    "./network-adpater": {
      "import": "./dist/client/partykit-network-adapter.js",
      "require": "./dist/client/partykit-network-adapter.cjs"
    },
    "./*": {
      "import": [
        "./dist/*.js",
        "./dist/*"
      ],
      "require": [
        "./dist/*.cjs",
        "./dist/*"
      ]
    }
  },
  "main": "dist/index.js",
  "directories": {
    "doc": "docs",
    "example": "example",
    "test": "test"
  },
  "files": [
    "./dist/*"
  ],
  "scripts": {
    "lint": "eslint \"./**/*.{ts,js}\"",
    "test": "npm run build && esbuild ./test/index.ts --bundle | tapout",
    "build-cjs": "esbuild src/**/*.ts --format=cjs --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --out-extension:.js=.cjs --sourcemap",
    "build-cjs:min": "esbuild src/**/*.ts --format=cjs --minify --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --out-extension:.js=.min.cjs --sourcemap",
    "build-esm": "esbuild src/**/*.ts --format=esm --metafile=dist/meta.json --keep-names --tsconfig=tsconfig.build.json --outdir=./dist --sourcemap && tsc --emitDeclarationOnly --project tsconfig.build.json --outDir dist",
    "build-esm:min": "esbuild ./src/**/*.ts --format=esm --keep-names --bundle --tsconfig=tsconfig.build.json --minify --out-extension:.js=.min.js --outdir=./dist --sourcemap",
    "build-example": "mkdir -p ./public && rm -rf ./public/* && VITE_DEBUG_MODE=staging vite --mode staging --base=\"/mergeparty\" build",
    "build-docs": "typedoc ./src/index.ts",
    "build": "mkdir -p ./dist && rm -rf ./dist/* && npm run build-cjs && npm run build-esm && npm run build-esm:min && npm run build-cjs:min",
    "start": "concurrently --kill-others \"npx partykit dev\" \"npx vite\"",
    "toc": "markdown-toc --maxdepth 3 -i README.md",
    "preversion": "npm run lint",
    "version": "npm run toc && auto-changelog -p --template keepachangelog --breaking-pattern 'BREAKING CHANGE:' && git add CHANGELOG.md README.md",
    "postversion": "git push --follow-tags && npm publish",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@automerge/automerge-repo": "^2.2.0",
    "@automerge/automerge-repo-network-websocket": "^2.2.0",
    "@automerge/automerge-repo-sync-server": "^0.2.8",
    "@substrate-system/automerge-repo-slim": "^2.3.2",
    "@substrate-system/debug": "^0.9.6",
    "automerge-repo-storage-memory": "^0.0.48",
    "partykit": "^0.0.115",
    "partysocket": "1.1.5"
  },
  "devDependencies": {
    "@automerge/automerge-repo-storage-indexeddb": "^2.2.0",
    "@cloudflare/workers-types": "^4.20250813.0",
    "@substrate-system/a11y": "^0.0.13",
    "@substrate-system/css-normalize": "^0.0.13",
    "@substrate-system/dom": "^0.1.7",
    "@substrate-system/signs": "^0.2.2",
    "@substrate-system/tapout": "^0.0.16",
    "@substrate-system/tapzero": "^0.10.15",
    "@substrate-system/text-input": "^0.1.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "auto-changelog": "^2.4.0",
    "concurrently": "^9.2.0",
    "dotenv": "^17.2.1",
    "esbuild": "^0.25.8",
    "eslint": "^8.57.0",
    "eslint-config-standard": "^17.1.0",
    "markdown-toc": "^1.2.0",
    "postcss-nesting": "^13.0.2",
    "tap-spec": "^5.0.0",
    "typedoc": "^0.28.9",
    "typescript": "^5.9.2",
    "vite": "^7.0.6",
    "vite-plugin-wasm": "^3.5.0"
  },
  "keywords": [
    "automerge",
    "crdt",
    "websocket",
    "partykit"
  ],
  "homepage": "https://github.com/substrate-system/mergeparty",
  "bugs": {
    "url": "https://github.com/substrate-system/mergeparty/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/substrate-system/mergeparty.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "author": "nichoth <nichoth@nichoth.com> (https://nichoth.com)"
}
